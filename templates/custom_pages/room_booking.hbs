<!-- ROOM_BOOKING_VERSION: 2026-03-27-06 -->
<link rel="stylesheet" href="{{asset 'training-bookings.css'}}">
<script>
  window.ROOM_BOOKING_CFG = {
    baseUrl: "https://script.google.com/macros/s/AKfycbwLge7qDCPemVqE2MsmB11HTZBOJcjFWYjj5yNLGzXKh_qVieGo8Yf5QWVTqt7xB_FU/exec",
    apiKey: "c8032a6a14e04710a701aadd27f8e5d5"
  };
</script>

<section class="training-bookings training-bookings--room-page">
  <div class="container">
    <p class="tb-build-tag" data-room-booking-build="2026-03-27-06">Room booking UI build 2026-03-27-06</p>
    <div class="tb-hero">
      <h1>Book Rooms</h1>
      <p class="tb-intro">
        Training Room 1 and Training Room 2 are available from 08:00 to 20:00 in 30-minute steps.
        The Interview Room (Meeting Room) is available from 12:00 to 20:00 in 60-minute slots.
      </p>
    </div>

    <div class="tb-guide" aria-label="How training room booking works">
      <div class="tb-guide__card">
        <span class="tb-guide__eyebrow">1. Choose the room</span>
        <p>Each room has its own calendar. Training Room 1, Training Room 2, and the Interview Room load separate availability.</p>
      </div>
      <div class="tb-guide__card">
        <span class="tb-guide__eyebrow">2. Drag to set the time</span>
        <p>Training rooms let you drag across 30-minute blocks. The Interview Room uses fixed 60-minute slots from 12:00 onward.</p>
      </div>
      <div class="tb-guide__card">
        <span class="tb-guide__eyebrow">3. Repeat days if needed</span>
        <p>The repeat selector checks the same time span on the next weekdays before you confirm the booking.</p>
      </div>
      <div class="tb-guide__card">
        <span class="tb-guide__eyebrow">4. Read the slot cues</span>
        <p>Open slots can be selected. Unavailable slots stay blocked. Hover or tap booked slots to see who reserved them.</p>
      </div>
    </div>

    {{#if signed_in}}
      <div
        id="training-booking-root"
        class="tb-app"
        data-room-booking-version="v3"
        data-room-base-url="https://script.google.com/macros/s/AKfycbwLge7qDCPemVqE2MsmB11HTZBOJcjFWYjj5yNLGzXKh_qVieGo8Yf5QWVTqt7xB_FU/exec"
        data-room-api-key="c8032a6a14e04710a701aadd27f8e5d5"
        data-room-image-training-1="{{asset 'room-preview-training-room-1.jpeg'}}"
        data-room-image-training-2="{{asset 'room-preview-training-room-2.jpeg'}}"
        data-room-image-interview="{{asset 'room-preview-interview-room.jpeg'}}"
      >
        <div id="training-booking-alert" class="tb-alert" role="status" aria-live="polite" hidden></div>

        <form id="training-booking-filters" class="tb-filters" autocomplete="off">
          <div class="tb-field">
            <label for="training-date">Start date</label>
            <input class="form-control" id="training-date" name="date" type="date" required>
          </div>
          <div class="tb-field">
            <label for="training-room">Room</label>
            <select class="form-control" id="training-room" name="room" required>
              <option value="Training Room 1">Training Room 1</option>
              <option value="Training Room 2">Training Room 2</option>
              <option value="Interview Room">Interview Room (Meeting Room)</option>
            </select>
          </div>
          <div class="tb-field">
            <label for="training-repeat-days">Repeat for next N weekdays</label>
            <select class="form-control" id="training-repeat-days" name="repeat_days">
              <option value="0">Do not repeat</option>
              <option value="1">1 additional day</option>
              <option value="2">2 additional days</option>
              <option value="3">3 additional days</option>
              <option value="4">4 additional days</option>
              <option value="5">5 additional days</option>
            </select>
          </div>
          <div class="tb-actions">
            <button class="btn btn-primary" id="training-load" type="submit">Refresh</button>
            <button class="btn btn-secondary" id="training-reset" type="button">Reset</button>
          </div>
        </form>

        <section id="training-room-preview" class="tb-room-preview" aria-live="polite">
          <div class="tb-room-preview__media">
            <img id="training-room-preview-image" class="tb-room-preview__image" alt="" hidden>
            <div id="training-room-preview-placeholder" class="tb-room-preview__placeholder"></div>
          </div>
          <div class="tb-room-preview__body">
            <span class="tb-room-preview__eyebrow">Selected room</span>
            <h2 id="training-room-preview-title" class="tb-room-preview__title">Training Room 1</h2>
            <p id="training-room-preview-caption" class="tb-room-preview__caption"></p>
          </div>
        </section>

        <div id="training-booking-loading" class="tb-loading" hidden>
          <span class="tb-spinner" aria-hidden="true"></span>
          <span>Loading room availability...</span>
        </div>

        <div id="training-booking-selection" class="tb-selection-summary" hidden></div>

        <div id="training-booking-list" class="tb-list">
          <div class="tb-placeholder">
            Choose a date and room to load the training calendar.
          </div>
        </div>

        <div id="training-booking-modal" class="tb-modal" aria-hidden="true" hidden>
          <div class="tb-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="training-booking-modal-title">
            <div class="tb-modal-header">
              <h2 class="tb-modal-title" id="training-booking-modal-title">Book Room</h2>
              <button class="tb-modal-close" type="button" id="training-booking-modal-close" aria-label="Close">x</button>
            </div>
            <div class="tb-modal-body">
              <div id="training-booking-session-summary" class="tb-session-summary"></div>
              <form id="training-booking-form" class="tb-form">
                <input id="training-booking-slot-id" name="slot_id" type="hidden">
                <input id="training-booking-start-date" name="start_date" type="hidden">
                <input id="training-booking-start-time" name="start_time" type="hidden">
                <input id="training-booking-end-time" name="end_time" type="hidden">
                <input id="training-booking-room-value" name="dept" type="hidden">
                <input id="training-booking-repeat-days-value" name="repeat_days" type="hidden">
                <div class="tb-form-grid">
                  <div class="tb-field">
                    <label for="training-booking-requester-name">Requester name</label>
                    <input class="form-control" id="training-booking-requester-name" name="requester_name" type="text" readonly required>
                  </div>
                  <div class="tb-field">
                    <label for="training-booking-requester-email">Requester email</label>
                    <input class="form-control" id="training-booking-requester-email" name="requester_email" type="email" readonly required>
                  </div>
                  <div class="tb-field">
                    <label for="training-booking-notes">Notes</label>
                    <textarea class="form-control" id="training-booking-notes" name="notes" rows="3" placeholder="Any questions or special requirements?"></textarea>
                  </div>
                  <div class="tb-field">
                    <label class="tb-checkbox" for="training-booking-online">
                      <input id="training-booking-online" name="online_meeting" type="checkbox" value="1">
                      <span>Include remote participants (create Google Meet link)</span>
                    </label>
                  </div>
                  <div class="tb-field" id="training-booking-attendees-field" hidden>
                    <label id="training-booking-attendees-label">Attendee emails</label>
                    <div id="training-booking-attendees" class="tb-attendee-list"></div>
                    <button class="btn btn-secondary" id="training-booking-add-attendee" type="button">+ Add attendee</button>
                  </div>
                </div>
                <div class="tb-modal-actions">
                  <button class="btn btn-primary" id="training-booking-submit" type="submit">Book now</button>
                  <button class="btn btn-secondary" id="training-booking-modal-cancel" type="button">Cancel</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    {{else}}
      <div class="tb-signed-out">
        <p>Please sign in to view and book training rooms.</p>
        <a class="btn btn-primary" href="/hc/{{help_center.locale}}/signin">Sign in</a>
      </div>
    {{/if}}
  </div>
</section>

<script src="{{asset 'training-bookings-calendar.js'}}" defer></script>
