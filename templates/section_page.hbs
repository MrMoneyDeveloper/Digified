<div class="container policies-container">
  <div class="sub-nav">
    {{breadcrumbs}}
  </div>

  <header class="section-header">
    <h1>{{section.name}}</h1>
    {{#if section.description}}
      <p class="section-description">{{section.description}}</p>
    {{/if}}
  </header>

  {{#if section.sections}}
    <div class="policy-cards-grid policy-cards-grid--sections">
      {{#each section.sections}}
        <article class="policy-card policy-card--section policy-card--{{@index}}">
          <div class="policy-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"></path>
            </svg>
          </div>
          <h2 class="policy-card__title">{{name}}</h2>
          {{#if description}}
            <p class="policy-card__description">{{description}}</p>
          {{/if}}
          <a href="{{url}}" class="policy-card__link">Open section &rarr;</a>
        </article>
      {{/each}}
    </div>
  {{/if}}

  {{#if section.articles}}
    <div class="policy-cards-grid">
      {{#each section.articles}}
        <article class="policy-card policy-card--{{@index}}">
          <div class="policy-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
          </div>
          <h2 class="policy-card__title">{{title}}</h2>
          <a href="{{url}}" class="policy-card__link">Read article &rarr;</a>
        </article>
      {{/each}}
    </div>
  {{/if}}

  {{#unless section.sections}}
    {{#unless section.articles}}
      <p class="section-description">No content is available in this section yet.</p>
    {{/unless}}
  {{/unless}}
</div>
